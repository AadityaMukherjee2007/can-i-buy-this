# ─── Can I Buy This? — Unified Environment ────────────────────────────────────
# Copy this to .env for local dev or set each var in your Vercel project dashboard.
#
#   cp .env.example .env
#
# There are 3 places you need to configure:
#
#   1. Root .env          → used by `docker compose up`
#   2. Frontend Vercel → set NEXT_PUBLIC_API_URL in dashboard
#   3. Backend Vercel  → set ALL non-commented vars in dashboard
#
# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED — Database
# ═══════════════════════════════════════════════════════════════════════════════
#
# Vercel requires IPv4 database connectivity. Supabase direct connections
# (port 5432) are IPv6-only, which does not work on Vercel.
# 
# If using Supabase, enable the connection pooler (Supavisor) in your
# Supabase dashboard (Project Settings → Database → Connection Pooler).
# Then use the pooler connection string as DATABASE_URL.
#
# Example pooler URL format:
# postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
#
# For local dev (Docker), use:
DATABASE_URL=postgresql+asyncpg://cibt_user:cibt_pass@localhost:5432/canibuythis

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED — Salt Edge (bank connections, sandbox works without real bank)
# ═══════════════════════════════════════════════════════════════════════════════
SALTEDGE_APP_ID=
SALTEDGE_SECRET=
SALTEDGE_ENV=sandbox

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED — Auth
# ═══════════════════════════════════════════════════════════════════════════════
JWT_SECRET=change-this-in-production

# ═══════════════════════════════════════════════════════════════════════════════
# FRONTEND — only needed for local dev (Docker compose sets it automatically)
# ═══════════════════════════════════════════════════════════════════════════════
# Set this in Vercel frontend project dashboard to your backend's Vercel URL.
# Example: NEXT_PUBLIC_API_URL=https://can-i-buy-this-backend.vercel.app
# NEXT_PUBLIC_API_URL=http://localhost:8000
