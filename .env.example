# ─── Can I Buy This? — Environment Configuration ─────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# The app works in demo mode with dummy data if only Salt Edge vars are missing.
# Set SALTEDGE_APP_ID and SALTEDGE_SECRET to enable live bank connections.

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED FOR LIVE BANK CONNECTIONS (Salt Edge)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Get these from https://www.saltedge.com/clients/applications
# Sandbox credentials work without a real bank account.

SALTEDGE_APP_ID=
SALTEDGE_SECRET=
SALTEDGE_ENV=sandbox

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — JWT Secret
# ═══════════════════════════════════════════════════════════════════════════════
# Used to sign auth tokens. Change this to a random string in production.
# Generate with: openssl rand -hex 32
JWT_SECRET=super-secret-key-change-in-production

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Stripe Payments (not yet wired to frontend)
# ═══════════════════════════════════════════════════════════════════════════════
# STRIPE_SECRET_KEY=sk_test_...

# ═══════════════════════════════════════════════════════════════════════════════
# Frontend (Next.js) — required for local dev, leave unset on Vercel (same-origin)
# ═══════════════════════════════════════════════════════════════════════════════
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ═══════════════════════════════════════════════════════════════════════════════
# INFRASTRUCTURE (Docker sets these automatically — only override for local dev)
# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE_URL=postgresql+asyncpg://cibt_user:cibt_pass@localhost:5433/canibuythis
