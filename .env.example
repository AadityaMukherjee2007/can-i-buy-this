# ─── Can I Buy This? — Environment Configuration ─────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# The app works in demo mode with dummy data if only Plaid vars are missing.
# Set PLAID_CLIENT_ID and PLAID_SECRET to enable live bank connections.

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED FOR LIVE BANK CONNECTIONS (Plaid)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Get these from https://dashboard.plaid.com → Developers → Keys
# Sandbox credentials work without a real bank account.
#
# PLAID_CLIENT_ID=your_client_id_here
# PLAID_SECRET=your_secret_here

PLAID_CLIENT_ID=
PLAID_SECRET=

# ─── Plaid environment ───────────────────────────────────────────────────────
# sandbox | production
# Sandbox allows testing with synthetic bank accounts (user_good, etc.)
# Production requires Plaid onboarding + proper credentials.
PLAID_ENV=sandbox

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — JWT Secret
# ═══════════════════════════════════════════════════════════════════════════════
# Used to sign auth tokens. Change this to a random string in production.
# Generate with: openssl rand -hex 32
JWT_SECRET=super-secret-key-change-in-production

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Stripe Payments (not yet wired to frontend)
# ═══════════════════════════════════════════════════════════════════════════════
# STRIPE_SECRET_KEY=sk_test_...

# ═══════════════════════════════════════════════════════════════════════════════
# Frontend (Next.js) — set on Netlify dashboard for production
# ═══════════════════════════════════════════════════════════════════════════════
# NEXT_PUBLIC_API_URL=https://your-backend-url.com

# ═══════════════════════════════════════════════════════════════════════════════
# INFRASTRUCTURE (Docker sets these automatically — only override for local dev)
# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE_URL=postgresql+asyncpg://cibt_user:cibt_pass@localhost:5433/canibuythis

